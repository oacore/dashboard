# Production / Docker build args (match GitHub secrets)
# Note: Do NOT set NODE_ENV in .env files – Vite blocks it. For Docker: NODE_ENV=development pnpm docker:build for dev.
BUILD_TARGET=azure
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NPM_TOKEN=
GA_TRACKING_CODE=

# Vite app config (used at build time)
VITE_APP_NAME=
VITE_APP_API_BASE_URL=
VITE_API_URL=
VITE_IDP_URL=
