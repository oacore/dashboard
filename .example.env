# Docker build args (match GitHub secrets)
BUILD_TARGET=azure
SENTRY_DSN=
NPM_TOKEN=
API_KEY=
GA_TRACKING_CODE=

# Vite mode: development (.env.development) or production (.env.production); default production
VITE_MODE=production

# Vite app config (used at build time when not using mode-based .env files)
VITE_APP_NAME=
VITE_APP_API_BASE_URL=
VITE_API_URL=
VITE_IDP_URL=
VITE_SENTRY_DSN=
VITE_GA_TRACKING_CODE=
