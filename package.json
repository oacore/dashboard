{
  "name": "dashboard-test-structure",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@oacore/core-ui"
    ]
  },
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build:core-ui": "cd ../core-ui && pnpm run build:lib",
    "dev": "vite --mode development",
